version: '3.7'

services:
  mysql:
    image: mysql
    container_name: mysql_app_1
    restart: always
    tty: true
    ports:
      - "3307:3306"
    environment:
      MYSQL_DATABASE: movies_db
      MYSQL_ROOT_PASSWORD: 123
      MYSQL_PASSWORD: ""
      SERVICES_TAGS: dev
      SERVICES_NAME: mysql
    volumes:
      - .sql:/docker-entrypoint-initdb.d
      - dbdata:/var/lib/mysql/
      - ./php/my.cnf:/ect/mysql/my.cnf
    networks:
     - app-networks
  app:
    build:
      args:
        user: sammy
        uid: 1000
      context: .
      dockerfile: Dockerfile
    
    image: php-fpm
    container_name: app_php
    restart: always
    tty: true
    ports:
      -"9000:9000"
    extra_hosts:
      - "internal.host:host-gateway"
    working_dir: /var/www
    environment:
      SERVICES_TAGS: dev
      SERVICES_NAME: app_php
    volumes:
      - ./:/var/www
      - /var/www/vendor
      - ./php/php.ini:/usr/local/ect/php/conf.d/local
    networks:
     - app-networks

  websercver:
    image: nginx:alpine
    container_name: project_webserver-app_php
    restart: always
    tty: true
    ports:
      -"8080:80"
    depends_on:
      - app
    volumes:
      - ./:/var/www
      - ./php/conf:/ect/nginx/conf.d
      - ./php/nginx/nginx.conf:/ect/nginx/nginx.conf:cached
    networks:
     - app-networks

networks:
  app-networks:
    driver: bridge

volumes:
  dbdata:
    driver: local

        - ./php/nginx/nginx.conf:/etc/nginx/nginx.conf:cached